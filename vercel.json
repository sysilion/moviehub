{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/cron/(.*)",
      "destination": "main.py"
    },
    {
      "source": "/(.*)",
      "destination": "main.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/discovery",
      "schedule": "0 0 * * *"
    }
  ]
}
